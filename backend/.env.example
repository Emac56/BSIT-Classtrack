# ================================================
# ClassTrack .env — I-copy ito at i-rename sa .env
# ================================================

# Server Port
PORT=3000

# ---- DATABASE ----
# Local PostgreSQL (para sa computer mo):
DB_NAME=classtrack
DB_USER=postgres
# DB_PASSWORD=yourpassword  (uncomment if may password ka)

# Cloud PostgreSQL (para sa Railway/Render deployment):
# DATABASE_URL=postgresql://username:password@host:5432/dbname

# ---- JWT SECRET (IMPORTANT!) ----
# Ito ang key para sa login tokens.
# HUWAG itong ibahagi o i-upload sa GitHub!
# Pwedeng kahit anong mahabang salita/phrase:
JWT_SECRET=classtrack-palitan-mo-to-ng-random-string-2024

# ---- ENVIRONMENT ----
# "development" o "production"
NODE_ENV=development

# ---- CORS (para sa production lang) ----
# ALLOWED_ORIGINS=https://yourwebsite.com
